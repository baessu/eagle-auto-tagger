# Copy to .env and fill in. Loaded automatically by watcher.py.
# (Plain `python3 auto_tag.py` reads these from your shell env, so either
#  `export` them or `set -a; source .env; set +a` before running.)

# Absolute path to your Eagle library folder (the directory ending in .library)
EAGLE_LIBRARY=/Users/you/Eagle/MyLibrary.library

# Optional: absolute path to the `claude` CLI binary.
# Default behavior: use `claude` found on PATH.
# CLAUDE_BIN=/usr/local/bin/claude

# Optional: comma-separated Eagle folder IDs whose items should also receive a
# generative-AI reproduction prompt (in the annotation field), not just tags.
# Two categories, each with its own analysis prompt. Leave empty to disable.
#   PHOTO        — photographic / editorial / product / lookbook
#   ILLUSTRATION — artwork / anime / concept / comics / paintings
# EAGLE_PROMPT_FOLDERS_PHOTO=FOLDER_ID_1,FOLDER_ID_2
# EAGLE_PROMPT_FOLDERS_ILLUSTRATION=FOLDER_ID_3
